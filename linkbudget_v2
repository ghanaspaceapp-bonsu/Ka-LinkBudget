    "Satellite -> Ground": sat_EIRP_dBW,
    "Lander -> Satellite": lander_EIRP_dBW,
    "Lander -> Ground": lander_EIRP_dBW,
}[selected]

freq = uplink_freq_Hz if "Uplink" in selected or "Lander -> Satellite" in selected else downlink_freq_Hz
G_T = sat_G_T_dB if "Satellite" in selected else ground_G_T_dB

eirp_values = [base_eirp + i * 0.5 for i in range(-20, 21)]
margin_values = [
    session_performance(
