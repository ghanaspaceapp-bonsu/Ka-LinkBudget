#!/usr/bin/env python3
import math

import pandas as pd
import streamlit as st
import altair as alt

# ---------------------------------------
# Constants
# ---------------------------------------
BOLTZMANN_DBW = -228.6  # dBW/K/Hz
T0_K = 290.0
LUNANET_VERSION = "V5"
MODULATION_TYPE = "GMSK"

# ---------------------------------------
# Helper functions
# ---------------------------------------

def fspl(freq_hz, dist_km):
    return 20.0 * math.log10(dist_km * 1000.0) + 20.0 * math.log10(freq_hz) - 147.55


def slant_range(distance_km, elevation_deg):
    elevation_rad = math.radians(max(min(elevation_deg, 89.9), 0.1))
    return distance_km / math.cos(elevation_rad)


def cn0(EIRP_dBW, G_T_dB, FSPL_dB, total_losses_dB):
    return EIRP_dBW + G_T_dB - FSPL_dB - total_losses_dB - BOLTZMANN_DBW


def ebn0_from_cn0(CN0_dBHz, Rb_bps):
    return CN0_dBHz - 10.0 * math.log10(Rb_bps)


def ber_gmsk(EbN0_dB):
    snr_linear = 10.0 ** (EbN0_dB / 10.0)
    x = math.sqrt(snr_linear / 2.0)
    return 0.5 * math.erfc(x)


def required_ebn0_for_ber_gmsk(target_ber):
    # For GMSK, approximate BER with 0.5*erfc(sqrt(Eb/N0/2)).
    if target_ber <= 0.0:
        return 0.0
    if target_ber >= 0.5:
        return 100.0

    def ber_from_ebn0(ebn0_dB):
        return ber_gmsk(ebn0_dB)

    lower = -10.0
    upper = 50.0
    for _ in range(60):
        mid = 0.5 * (lower + upper)
        if ber_from_ebn0(mid) > target_ber:
            lower = mid
        else:
            upper = mid
    return upper


def required_cn0_for_ber(target_ber, bit_rate_bps, coding_gain_dB, coding_threshold_dB):
    required_ebn0_dB = required_ebn0_for_ber_gmsk(target_ber) - coding_gain_dB + coding_threshold_dB
    return required_ebn0_dB + 10.0 * math.log10(bit_rate_bps)


def lunar_noise_loss_dB(lunar_noise_temp_K, receiver_temp_K):
    return 10.0 * math.log10((receiver_temp_K + lunar_noise_temp_K) / T0_K)


def coding_requirement(required_dB, coding_gain_dB, coding_threshold_dB):
    return required_dB - coding_gain_dB + coding_threshold_dB


def total_loss_budget(losses):
    return sum(losses.values())


def session_performance(
    name,
    EIRP_dBW,
    G_T_dB,
    freq_Hz,
    distance_km,
    elevation_deg,
    bit_rate_bps,
    total_losses_dB,
    lunar_noise_temp_K,
    receiver_temp_K,
    required_EbN0_dB,
    coding_gain_dB,
    coding_threshold_dB,
    target_BER,
):
    slant_km = slant_range(distance_km, elevation_deg)
    FSPL_dB = fspl(freq_Hz, slant_km)
    lunar_noise_dB = lunar_noise_loss_dB(lunar_noise_temp_K, receiver_temp_K)
    effective_G_T_dB = G_T_dB - lunar_noise_dB
    CN0_dBHz = cn0(EIRP_dBW, effective_G_T_dB, FSPL_dB, total_losses_dB)
    EbN0_dB = ebn0_from_cn0(CN0_dBHz, bit_rate_bps)
    required_dB = coding_requirement(required_EbN0_dB, coding_gain_dB, coding_threshold_dB)
    target_EbN0_dB = required_ebn0_for_ber_gmsk(target_BER) - coding_gain_dB + coding_threshold_dB
    required_CN0_dBHz = required_cn0_for_ber(target_BER, bit_rate_bps, coding_gain_dB, coding_threshold_dB)
    margin_dB = EbN0_dB - required_dB
    ber_margin_dB = EbN0_dB - target_EbN0_dB
    cn0_margin_dB = CN0_dBHz - required_CN0_dBHz
    achieved = ber_gmsk(EbN0_dB) <= target_BER
    cn0_achieved = CN0_dBHz >= required_CN0_dBHz
    return {
        "Session": name,
        "Slant range (km)": slant_km,
        "FSPL (dB)": FSPL_dB,
        "C/N0 (dB-Hz)": CN0_dBHz,
        "Eb/N0 (dB)": EbN0_dB,
        "Required Eb/N0 (dB)": required_dB,
        "Target Eb/N0 for BER (dB)": target_EbN0_dB,
        "Required C/N0 for BER (dB-Hz)": required_CN0_dBHz,
        "C/N0 margin (dB)": cn0_margin_dB,
        "Margin (dB)": margin_dB,
        "BER margin (dB)": ber_margin_dB,
        "BER": ber_gmsk(EbN0_dB),
        "BER target met": achieved,
        "C/N0 target met": cn0_achieved,
    }


