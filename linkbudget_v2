# ---------------------------------------
# Constants
# ---------------------------------------
BOLTZMANN_DBW = -228.6  # dBW/K/Hz
T0_K = 290.0
LUNANET_VERSION = "V5"
MODULATION_TYPE = "GMSK"

# ---------------------------------------
# Helper functions
# ---------------------------------------

def fspl(freq_hz, dist_km):
    return 20.0 * math.log10(dist_km * 1000.0) + 20.0 * math.log10(freq_hz) - 147.55


def slant_range(distance_km, elevation_deg):
    elevation_rad = math.radians(max(min(elevation_deg, 89.9), 0.1))
    return distance_km / math.cos(elevation_rad)


def cn0(EIRP_dBW, G_T_dB, FSPL_dB, total_losses_dB):
    return EIRP_dBW + G_T_dB - FSPL_dB - total_losses_dB - BOLTZMANN_DBW


def ebn0_from_cn0(CN0_dBHz, Rb_bps):
    return CN0_dBHz - 10.0 * math.log10(Rb_bps)


def ber_gmsk(EbN0_dB):
    snr_linear = 10.0 ** (EbN0_dB / 10.0)
    x = math.sqrt(snr_linear / 2.0)
    return 0.5 * math.erfc(x)


def required_ebn0_for_ber_gmsk(target_ber):
    # For GMSK, approximate BER with 0.5*erfc(sqrt(Eb/N0/2)).
    if target_ber <= 0.0:
        return 0.0
    if target_ber >= 0.5:
        return 100.0

    def ber_from_ebn0(ebn0_dB):
        return ber_gmsk(ebn0_dB)

    lower = -10.0
    upper = 50.0
    for _ in range(60):
        mid = 0.5 * (lower + upper)
        if ber_from_ebn0(mid) > target_ber:
            lower = mid
        else:
            upper = mid
    return upper


def required_cn0_for_ber(target_ber, bit_rate_bps, coding_gain_dB, coding_threshold_dB):
    required_ebn0_dB = required_ebn0_for_ber_gmsk(target_ber) - coding_gain_dB + coding_threshold_dB
    return required_ebn0_dB + 10.0 * math.log10(bit_rate_bps)


def lunar_noise_loss_dB(lunar_noise_temp_K, receiver_temp_K):
    return 10.0 * math.log10((receiver_temp_K + lunar_noise_temp_K) / T0_K)


def coding_requirement(required_dB, coding_gain_dB, coding_threshold_dB):
    return required_dB - coding_gain_dB + coding_threshold_dB


def noise_power_density_dBWHz(system_noise_temp_K):
    return BOLTZMANN_DBW + 10.0 * math.log10(system_noise_temp_K)


def pdf_escape_text(text: str) -> str:
    return text.replace("\\", "\\\\").replace("(", "\\(").replace(")", "\\)")


def make_pdf_bytes(results: pd.DataFrame, scenario_df: pd.DataFrame, noise_df: pd.DataFrame) -> bytes:
    lines = [
        "BONSU LINK BUDGET EXPLORER",
        "",
        "Session Summary:",
    ]
    lines += [f"{row['Session']}: C/N0={row['C/N0 (dB-Hz)']:.2f} dB-Hz, Eb/N0={row['Eb/N0 (dB)']:.2f} dB, BER={row['BER']}" for _, row in results.iterrows()]
    lines += ["", "Doppler scenarios:"]
    for _, row in scenario_df.iterrows():
        lines.append(f"{row['Scenario']}: uplink={row['Uplink Doppler shift (kHz)']} kHz, downlink={row['Downlink Doppler shift (kHz)']} kHz")
    lines += ["", "Noise power density table:"]
    for _, row in noise_df.iterrows():
        lines.append(f"C/N0={row['C/N0 (dB-Hz)']} dB-Hz, N0={row['N0 (dBW/Hz)']:.2f}, Carrier={row['Carrier power (dBW)']:.2f}")

    content_lines = [pdf_escape_text(line) for line in lines]
    content = "BT /F1 12 Tf 50 760 Td\n"
    for i, line in enumerate(content_lines):
        if i > 0:
            content += "T*\n"
        content += f"({line}) Tj\n"
    content += "ET"

    content_bytes = content.encode("latin-1")
    objects = []
    offsets = []
    pdf = b"%PDF-1.4\n"

    # Catalog
    offsets.append(len(pdf))
    objects.append(b"1 0 obj\n<< /Type /Catalog /Pages 2 0 R >>\nendobj\n")
    pdf += objects[-1]

    # Pages
    offsets.append(len(pdf))
    objects.append(b"2 0 obj\n<< /Type /Pages /Kids [3 0 R] /Count 1 >>\nendobj\n")
    pdf += objects[-1]

    # Page
    offsets.append(len(pdf))
    page_stream = (
        b"3 0 obj\n<< /Type /Page /Parent 2 0 R /MediaBox [0 0 612 792] /Resources << /Font << /F1 4 0 R >> >> /Contents 5 0 R >>\nendobj\n"
    )
    objects.append(page_stream)
    pdf += objects[-1]

    # Font
    offsets.append(len(pdf))
    objects.append(b"4 0 obj\n<< /Type /Font /Subtype /Type1 /BaseFont /Courier >>\nendobj\n")
    pdf += objects[-1]

    # Content
    offsets.append(len(pdf))
    stream = content_bytes
    stream_obj = f"5 0 obj\n<< /Length {len(stream)} >>\nstream\n".encode("latin-1") + stream + b"\nendstream\nendobj\n"
    objects.append(stream_obj)
    pdf += objects[-1]

    xref_offset = len(pdf)
    pdf += b"xref\n0 6\n0000000000 65535 f \n"
    for offset in offsets:
        pdf += f"{offset:010d} 00000 n \n".encode("latin-1")
    pdf += b"trailer\n<< /Size 6 /Root 1 0 R >>\nstartxref\n"
    pdf += f"{xref_offset}\n".encode("latin-1")
    pdf += b"%%EOF\n"
    return pdf


def make_excel_bytes(results: pd.DataFrame, scenario_df: pd.DataFrame, noise_df: pd.DataFrame) -> bytes | None:
    engine = None
    if importlib.util.find_spec("openpyxl") is not None:
        engine = "openpyxl"
    elif importlib.util.find_spec("xlsxwriter") is not None:
        engine = "xlsxwriter"
    if engine is None:
        return None

    output = BytesIO()
    with pd.ExcelWriter(output, engine=engine) as writer:
        results.to_excel(writer, sheet_name="Session Results")
        scenario_df.to_excel(writer, sheet_name="Doppler Scenarios", index=False)
        noise_df.to_excel(writer, sheet_name="Noise vs CNo", index=False)
    output.seek(0)
    return output.read()


SPEED_OF_LIGHT_M_S = 299792458.0


def doppler_shift_hz(freq_hz, relative_velocity_m_s):
    return freq_hz * (relative_velocity_m_s / SPEED_OF_LIGHT_M_S)


def scenario_doppler_analysis(scenarios, uplink_freq_Hz, downlink_freq_Hz):
    rows = []
    for scenario in scenarios:
        uplink_shift_hz = doppler_shift_hz(uplink_freq_Hz, scenario["velocity_m_s"])
        downlink_shift_hz = doppler_shift_hz(downlink_freq_Hz, scenario["velocity_m_s"])
        rows.append({
            "Scenario": scenario["name"],
            "Assumption": scenario["description"],
            "Relative velocity (m/s)": scenario["velocity_m_s"],
            "Uplink Doppler shift (kHz)": round(uplink_shift_hz / 1e3, 3),
            "Downlink Doppler shift (kHz)": round(downlink_shift_hz / 1e3, 3),
        })
    return pd.DataFrame(rows)


def total_loss_budget(losses):
    return sum(losses.values())


def session_performance(
    name,
    EIRP_dBW,
    G_T_dB,
    freq_Hz,
    distance_km,
    elevation_deg,
    bit_rate_bps,
    total_losses_dB,
    lunar_noise_temp_K,
    receiver_temp_K,
    required_EbN0_dB,
    coding_gain_dB,
    coding_threshold_dB,
    target_BER,
):
    slant_km = slant_range(distance_km, elevation_deg)
    FSPL_dB = fspl(freq_Hz, slant_km)
    lunar_noise_dB = lunar_noise_loss_dB(lunar_noise_temp_K, receiver_temp_K)
    effective_G_T_dB = G_T_dB - lunar_noise_dB
    CN0_dBHz = cn0(EIRP_dBW, effective_G_T_dB, FSPL_dB, total_losses_dB)
    EbN0_dB = ebn0_from_cn0(CN0_dBHz, bit_rate_bps)
    required_dB = coding_requirement(required_EbN0_dB, coding_gain_dB, coding_threshold_dB)
    target_EbN0_dB = required_ebn0_for_ber_gmsk(target_BER) - coding_gain_dB + coding_threshold_dB
    required_CN0_dBHz = required_cn0_for_ber(target_BER, bit_rate_bps, coding_gain_dB, coding_threshold_dB)
    margin_dB = EbN0_dB - required_dB
    ber_margin_dB = EbN0_dB - target_EbN0_dB
    cn0_margin_dB = CN0_dBHz - required_CN0_dBHz
    achieved = ber_gmsk(EbN0_dB) <= target_BER
    cn0_achieved = CN0_dBHz >= required_CN0_dBHz
    noise_temp_K_total = receiver_temp_K + lunar_noise_temp_K
    noise_density_dBWHz = noise_power_density_dBWHz(noise_temp_K_total)
    carrier_power_dBW = CN0_dBHz + noise_density_dBWHz
    return {
        "Session": name,
        "Slant range (km)": slant_km,
        "FSPL (dB)": FSPL_dB,
        "C/N0 (dB-Hz)": CN0_dBHz,
        "Eb/N0 (dB)": EbN0_dB,
        "Required Eb/N0 (dB)": required_dB,
        "Target Eb/N0 for BER (dB)": target_EbN0_dB,
        "Required C/N0 for BER (dB-Hz)": required_CN0_dBHz,
        "C/N0 margin (dB)": cn0_margin_dB,
        "Margin (dB)": margin_dB,
        "BER margin (dB)": ber_margin_dB,
        "BER": ber_gmsk(EbN0_dB),
        "BER target met": achieved,
        "C/N0 target met": cn0_achieved,
        "N0 (dBW/Hz)": noise_density_dBWHz,
        "Carrier power (dBW)": carrier_power_dBW,
    }


