        eirp,
        G_T,
        freq,
        distance_km,
        elevation_deg,
        bit_rate_bps,
        loss_budget_dB,
        lunar_noise_temp_K,
        receiver_temp_K,
        required_EbN0_dB,
        coding_gain_dB,
        coding_threshold_dB,
