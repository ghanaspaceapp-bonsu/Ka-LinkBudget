    ).interactive()
    st.altair_chart(chart, use_container_width=True)
with col2:
    st.write("### Margin vs Data Rate")
    chart_df = pd.DataFrame({"Data rate (Mbps)": [r / 1e6 for r in rate_values], "Margin (dB)": margin_rate_values})
    chart = alt.Chart(chart_df).mark_line(point=True).encode(
