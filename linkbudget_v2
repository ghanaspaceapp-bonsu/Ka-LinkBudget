    )["Margin (dB)"]
    for eirp in eirp_values
]

rate_values = [max(1000.0, bit_rate_bps * factor) for factor in [0.25, 0.5, 1.0, 1.5, 2.0]]
margin_rate_values = [
    session_performance(
        selected,
        base_eirp,
        G_T,
        freq,
        distance_km,
        elevation_deg,
        rate,
        loss_budget_dB,
        lunar_noise_temp_K,
        receiver_temp_K,
        required_EbN0_dB,
        coding_gain_dB,
        coding_threshold_dB,
        target_BER,
    )["Margin (dB)"]
    for rate in rate_values
]

ebn0_values = [i * 0.5 for i in range(0, 41)]
ber_values = [ber_gmsk(x) for x in ebn0_values]

col1, col2, col3 = st.columns(3)
with col1:
    st.write("### EIRP vs Margin")
    chart_df = pd.DataFrame({"EIRP (dBW)": eirp_values, "Margin (dB)": margin_values})
    chart = alt.Chart(chart_df).mark_line(point=True).encode(
