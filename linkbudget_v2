    ground_G_T_dB = st.number_input("Ground G/T (dB/K)", value=48.9, step=0.1)
    sat_G_T_dB = st.number_input("Satellite G/T (dB/K)", value=8.6, step=0.1)
    lander_G_T_dB = st.number_input("Lander G/T (dB/K)", value=5.0, step=0.1)
    lunar_noise_temp_K = st.number_input("Lunar noise temperature (K)", value=50.0, step=1.0)
    receiver_temp_K = st.number_input("Receiver noise temperature (K)", value=150.0, step=1.0)

losses = {
